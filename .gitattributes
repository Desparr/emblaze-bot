# .gitattributes -- Emtech app-author contract (Emtech-LLC/starthere).
# Emtech builds Docker images on Linux CI, never on the dev machine. A shell
# script or Dockerfile checked out with Windows CRLF breaks the Linux build
# (e.g. `/bin/sh^M: bad interpreter`). Enforcing LF keeps the checkout
# identical regardless of dev OS. See starthere/conventions/windows-dev-gotchas.md.

* text=auto

*.sh          text eol=lf
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf

*.py          text eol=lf
*.md          text eol=lf
*.env.example text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
